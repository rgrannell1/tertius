#!/usr/bin/env bash
set -euo pipefail

# Parse --reruns N flag for flakiness measurement; remaining args pass through to pytest
RERUNS=0
PYTEST_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --reruns)
      RERUNS="$2"
      shift 2
      ;;
    *)
      PYTEST_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ "$RERUNS" -eq 0 ]]; then
  uv run python3 -m pytest -v "${PYTEST_ARGS[@]+"${PYTEST_ARGS[@]}"}"
else
  PASS=0
  FAIL=0
  for run in $(seq 1 "$RERUNS"); do
    echo "--- Run $run / $RERUNS ---"
    if uv run python3 -m pytest -v "${PYTEST_ARGS[@]+"${PYTEST_ARGS[@]}"}"; then
      PASS=$((PASS + 1))
    else
      FAIL=$((FAIL + 1))
    fi
  done
  echo ""
  echo "Rerun summary: $PASS/$RERUNS passed, $FAIL/$RERUNS failed"
  if [[ "$FAIL" -gt 0 ]]; then
    exit 1
  fi
fi
